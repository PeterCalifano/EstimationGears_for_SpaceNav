/**
 * @file config.h.in
 * @author PeterC (petercalifano.gs@gmail.com)
 * @brief Configuration header file for library src, with variables set by CMake
 * @version 0.1
 * @date 2025-01-04
 */
#pragma once
#include <cstdio>
#include <string>

// Library version
#define PROJECT_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define PROJECT_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define PROJECT_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define PROJECT_VERSION "@PROJECT_VERSION@"
#define FULL_VERSION "@FULL_VERSION@"

inline void PrintVersion()
{
    std::printf("Application Version: %s\n", PROJECT_VERSION);
    std::printf("Full Version: %s\n", FULL_VERSION);
    std::printf("Version Details:\n");
    std::printf("Major: %d\n", PROJECT_VERSION_MAJOR);
    std::printf("Minor: %d\n", PROJECT_VERSION_MINOR);
    std::printf("Patch: %d\n", PROJECT_VERSION_PATCH);
    std::printf("Build Date: %s\n", __DATE__);
    std::printf("Build Time: %s\n", __TIME__);
}

inline std::string GetVersionString()
{
    return std::string(PROJECT_VERSION);
}

#cmakedefine VARIABLE_DEFINED_BY_CMAKE // This is a placeholder for a variable defined by CMake. If it is not define, the #define is not included in the output file from configure_file().
